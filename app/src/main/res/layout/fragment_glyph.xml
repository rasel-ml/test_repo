<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/bgSidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="?attr/textSecondary"
        app:title="@string/glyph_map"
        app:titleTextColor="?attr/textPrimary">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="140dp"
            android:layout_height="36dp"
            android:layout_gravity="end"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_search_small"
            android:hint="U+0041…"
            android:textColorHint="?attr/textMuted"
            android:textColor="?attr/textPrimary"
            android:textSize="13sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:singleLine="true" />

    </androidx.appcompat.widget.Toolbar>

    <!-- Stats bar -->
    <TextView
        android:id="@+id/tv_glyph_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:paddingStart="16dp"
        android:textColor="?attr/textMuted"
        android:textSize="12sp"
        android:letterSpacing="0.05"
        android:background="?attr/bgSidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar" />

    <!-- Glyph grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_glyphs"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingTop="4dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/pagination_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_glyph_count" />

    <!-- Pagination -->
    <LinearLayout
        android:id="@+id/pagination_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="10dp"
        android:background="?attr/bgSidebar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/btn_prev"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="‹"
            android:textSize="22sp"
            android:textColor="?attr/textSecondary"
            android:background="@drawable/bg_style_btn"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tv_page"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:textColor="?attr/textMuted"
            android:textSize="13sp"
            android:text="1 / 1" />

        <TextView
            android:id="@+id/btn_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="›"
            android:textSize="22sp"
            android:textColor="?attr/textSecondary"
            android:background="@drawable/bg_style_btn"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
