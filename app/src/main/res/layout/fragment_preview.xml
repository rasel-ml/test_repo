<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgPrimary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/bgSidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_back"
        app:navigationIconTint="?attr/textSecondary">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/tv_font_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:fontFamily="serif"
                android:maxLines="1"
                android:ellipsize="end"
                android:letterSpacing="0.04" />

            <!-- Add to Library (temp mode only) -->
            <TextView
                android:id="@+id/btn_add_to_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ Add"
                android:textSize="13sp"
                android:textColor="?attr/colorOnPrimary"
                android:background="@drawable/bg_accent_btn"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone" />

            <TextView
                android:id="@+id/btn_delete"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🗑"
                android:textSize="16sp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btn_info"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="ℹ"
                android:textSize="18sp"
                android:textColor="?attr/textSecondary"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btn_meta"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="⊙"
                android:textSize="18sp"
                android:textColor="?attr/textSecondary"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btn_glyph"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="⌨"
                android:textSize="18sp"
                android:textColor="?attr/textSecondary"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/btn_favorite"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="☆"
                android:textSize="20sp"
                android:textColor="?attr/textMuted"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/controls_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp"
        android:background="?attr/bgSidebar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <TextView
            android:id="@+id/tv_size_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="32px"
            android:textColor="?attr/textMuted"
            android:textSize="12sp"
            android:minWidth="52dp" />

        <SeekBar
            android:id="@+id/seekbar_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="152"
            android:progress="24"
            android:progressTint="?attr/accentColor"
            android:thumbTint="?attr/accentColor" />

        <TextView
            android:id="@+id/btn_bold"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="B"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/textMuted"
            android:background="@drawable/bg_style_btn"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_italic"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="I"
            android:textSize="16sp"
            android:textStyle="italic"
            android:fontFamily="serif"
            android:textColor="?attr/textMuted"
            android:background="@drawable/bg_style_btn"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="?attr/dividerColor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/controls_bar" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider">

        <EditText
            android:id="@+id/et_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:padding="24dp"
            android:background="@null"
            android:textColor="?attr/textPrimary"
            android:textSize="32sp"
            android:gravity="top|start"
            android:hint="@string/tap_to_type"
            android:textColorHint="?attr/textMuted"
            android:inputType="textMultiLine|textCapSentences"
            android:lineSpacingMultiplier="1.4" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
