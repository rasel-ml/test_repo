<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_spacing"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="?attr/bgSurface"
    app:cardCornerRadius="@dimen/card_radius"
    app:cardElevation="0dp"
    app:strokeColor="?attr/dividerColor"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <!-- Row 1: Names (left) + action buttons (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: family name + subfamily below -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <!-- Family name: bold, 15sp -->
                <TextView
                    android:id="@+id/tv_font_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/textPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- tv_font_sub: kept for binding compat, not displayed -->
                <TextView
                    android:id="@+id/tv_font_sub"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Right: font-type badge, favorite, delete — in that order -->

            <!-- Font type badge (TTF / OTF / etc.) — same height as icon buttons -->
            <TextView
                android:id="@+id/tv_font_type"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginEnd="6dp"
                android:gravity="center"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:fontFamily="monospace"
                android:textColor="?attr/colorPrimary"
                android:paddingStart="9dp"
                android:paddingEnd="9dp"
                android:clickable="false"
                android:focusable="false" />

            <!-- Favorite -->
            <ImageView
                android:id="@+id/btn_favorite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_star_outline"
                android:scaleType="fitCenter"
                android:clickable="true"
                android:focusable="true" />

            <!-- Delete -->
            <ImageView
                android:id="@+id/btn_remove"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:padding="7dp"
                android:src="@drawable/ic_delete"
                android:scaleType="fitCenter"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Row 2: Script label row — pipe-separated tappable names -->
        <HorizontalScrollView
            android:id="@+id/hsv_script_chips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_script_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <!-- Row 3: Preview text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/btn_cycle_script"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:gravity="center"
                android:text="↻"
                android:textSize="16sp"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_preview_large"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/textSecondary"
                android:textSize="26sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.2" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_preview_small"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
