<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SORT BY"
        android:textColor="?attr/accentColor"
        android:textSize="16sp"
        android:letterSpacing="0.12"
        android:paddingStart="20dp"
        android:paddingBottom="8dp" />

    <RadioGroup
        android:id="@+id/rg_sort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <RadioButton android:id="@+id/rb_name_asc"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Name  A → Z"
            android:textColor="?attr/textPrimary" android:textSize="14sp"
            android:buttonTint="?attr/accentColor" android:paddingStart="8dp" />
        <RadioButton android:id="@+id/rb_name_desc"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Name  Z → A"
            android:textColor="?attr/textPrimary" android:textSize="14sp"
            android:buttonTint="?attr/accentColor" android:paddingStart="8dp" />
        <RadioButton android:id="@+id/rb_date_asc"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Date  Oldest first"
            android:textColor="?attr/textPrimary" android:textSize="14sp"
            android:buttonTint="?attr/accentColor" android:paddingStart="8dp" />
        <RadioButton android:id="@+id/rb_date_desc"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Date  Newest first"
            android:textColor="?attr/textPrimary" android:textSize="14sp"
            android:buttonTint="?attr/accentColor" android:paddingStart="8dp" />
        <RadioButton android:id="@+id/rb_folder"
            android:layout_width="match_parent" android:layout_height="48dp"
            android:text="Folder"
            android:textColor="?attr/textPrimary" android:textSize="14sp"
            android:buttonTint="?attr/accentColor" android:paddingStart="8dp" />

    </RadioGroup>

</LinearLayout>
