    <!-- ════════════════════════════════════════════════════════════════════
         Shared card styles per theme
    ════════════════════════════════════════════════════════════════════ -->
    <style name="CardStyle.Green.Light"  parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/green_light_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/green_light_divider</item><item name="strokeWidth">1dp</item></style>
    <style name="CardStyle.Green.Dark"   parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/green_dark_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/green_dark_divider</item><item name="strokeWidth">1dp</item></style>
    <style name="CardStyle.Blue.Light"   parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/blue_light_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/blue_light_divider</item><item name="strokeWidth">1dp</item></style>
    <style name="CardStyle.Blue.Dark"    parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/blue_dark_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/blue_dark_divider</item><item name="strokeWidth">1dp</item></style>
    <style name="CardStyle.Red.Light"    parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/red_light_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/red_light_divider</item><item name="strokeWidth">1dp</item></style>
