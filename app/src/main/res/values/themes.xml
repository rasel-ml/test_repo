    <!-- ════════════════════════════════════════════════════════════════════
         Shared dialogs / bottom sheets (reference accent via colorPrimary)
    ════════════════════════════════════════════════════════════════════ -->
    <style name="Theme.FontLens.BottomSheet" parent="Theme.MaterialComponents.BottomSheetDialog">
        <item name="android:colorBackground">?attr/colorSurface</item>
    </style>

    <style name="AccentButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="OutlineButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">?attr/colorOnSurface</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="Theme.FontLens.Dialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">?attr/colorPrimary</item>
        <item name="colorOnSurface">?attr/colorOnSurface</item>
        <item name="android:colorBackground">?attr/colorSurface</item>
        <item name="android:textColorPrimary">?attr/colorOnSurface</item>
        <item name="buttonBarPositiveButtonStyle">@style/AccentButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/OutlineButton</item>
    </style>

</resources>
