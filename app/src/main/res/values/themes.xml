    <style name="CardStyle.Yellow.Light" parent="Widget.MaterialComponents.CardView"><item name="cardBackgroundColor">@color/yellow_light_bg_surface</item><item name="cardCornerRadius">8dp</item><item name="cardElevation">0dp</item><item name="strokeColor">@color/yellow_light_divider</item><item name="strokeWidth">1dp</item></style>
